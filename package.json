{
  "name": "bevy-osc",
  "module": "index.ts",
  "type": "module",
  "author": "Geoff Seemueller 2026",
  "private": true,
  "scripts": {
    "build:web": "CARGO_TARGET_DIR=target cargo build --release --target wasm32-unknown-unknown && wasm-bindgen --out-dir dist/pkg --out-name bevyosc --target web target/wasm32-unknown-unknown/release/bevyosc.wasm",
    "check:wasm": "CARGO_TARGET_DIR=target cargo check --target wasm32-unknown-unknown",
    "check:vst": "cargo check -p bevyosc-vst",
    "clippy:wasm": "CARGO_TARGET_DIR=target cargo clippy --target wasm32-unknown-unknown -- -D warnings",
    "clippy:vst": "cargo clippy -p bevyosc-vst -- -D warnings",
    "clippy": "bun run clippy:wasm && bun run clippy:vst",
    "build:vst": "CARGO_TARGET_DIR=target-vst cargo run -p xtask -- bundle bevyosc-vst --release",
    "install:vst:mac": "mkdir -p \"$HOME/Library/Audio/Plug-Ins/VST3\" && cp -R \"target-vst/bundled/bevyosc VJ Bridge.vst3\" \"$HOME/Library/Audio/Plug-Ins/VST3/\"",
    "serve": "bun run index.ts",
    "dev": "bun run build:web && bun run serve",
    "test": "bun run test:rust && bun run test:web",
    "test:rust": "bash scripts/test-rust.sh",
    "test:web": "vitest run",
    "postinstall": "bash .dev/setup-git-hooks.sh",
    "typecheck": "tsc --noEmit",
    "format": "bash scripts/format-code.sh"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@vitest/browser": "^4.0.0",
    "@vitest/browser-playwright": "^4.0.0",
    "playwright": "^1.50.0",
    "vitest": "^4.0.0"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "osc": "^2.4.5"
  }
}
